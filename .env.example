# LINE Messaging API
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# Google AI Studio (Gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Public base URL of this server (no trailing slash)
# Local: https://xxxx.ngrok-free.app
# Prod:  https://your-app.onrender.com
BASE_URL=https://your-public-https-url

# Google OAuth (Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must equal: {BASE_URL}/oauth/callback  and be listed in Google Cloud Console
GOOGLE_REDIRECT_URI=https://your-public-https-url/oauth/callback

# Optional: Flask secret for session cookies during OAuth
FLASK_SECRET_KEY=change-me-to-a-long-random-string

# Server
PORT=8000
HOST=0.0.0.0

# Optional: persistent data path (Render disk mount)
# DATA_DIR=/var/data
