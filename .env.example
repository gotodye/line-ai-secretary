# LINE Messaging API
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# Google AI Studio (Gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Public base URL of this server (no trailing slash)
# Local: https://xxxx.ngrok-free.app
# Prod:  https://your-app.onrender.com
BASE_URL=https://your-public-https-url

# Google OAuth (Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must equal: {BASE_URL}/oauth/callback  and be listed in Google Cloud Console
GOOGLE_REDIRECT_URI=https://your-public-https-url/oauth/callback

# Optional: Flask secret for session cookies during OAuth
FLASK_SECRET_KEY=change-me-to-a-long-random-string

# External storage (Upstash Redis → Console → 資料庫 → REST API)
# 正式環境必填：Render 免費方案沒有持久磁碟，不設就會在每次重啟後遺失所有授權。
# 本機開發可留空，會自動退回 data/store.json。
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# 加密存放的 Google token。用 pwsh scripts/generate_keys.ps1 產生。
# 設了 Upstash 就必填；更換金鑰會讓所有使用者需要重新連結 Google。
TOKEN_ENCRYPTION_KEY=

# 晨間簡報端點 /cron/brief 的通行密碼，由外部排程服務呼叫時帶上。
# 未設定則該端點一律回 503，不會對外開放。
CRON_SECRET=

# Server
PORT=8000
HOST=0.0.0.0

# Local dev data path (Upstash 未設定時的退回位置)
# DATA_DIR=./data
